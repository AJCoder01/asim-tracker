# ==============================================================================
# ASIM-Tracker Local Environment Configuration Template
# Copy this file to a new file named '.env' in the same folder and fill in your details.
# WARNING: NEVER commit the completed '.env' file containing your actual keys to Git.
# ==============================================================================

# 1. Database & Queue Endpoints (Uncomment and customize if using non-defaults)
# SQLITE_DB_PATH=asim_tracker.db
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# 2. Broker Credentials & OAuth Keys (Supported: "angel_one" or "dhan")
BROKER_NAME=angel_one
BROKER_CLIENT_ID=YOUR_CLIENT_ID
BROKER_PASSWORD=YOUR_PASSWORD
BROKER_PIN=YOUR_MPIN
BROKER_TOTP_KEY=YOUR_TOTP_SECRET_KEY
BROKER_API_KEY=YOUR_DEVELOPER_API_KEY
BROKER_REDIRECT_URL=http://127.0.0.1:5000

# 3. Risk Sentinel & Trading Controls (Uncomment and customize if needed)
# MAX_CAPITAL=5000.0
# MAX_POSITIONS=1
# MAX_TRADES_PER_DAY=2
# MAX_ASSET_PRICE=200.0
# CIRCUIT_MARGIN_PCT=1.5
# OPS_LIMIT_SLEEP=0.15

# 4. Model Engine & Calibration Configurations (Uncomment and customize if needed)
# ONNX_FINBERT_PATH=model_engine/finbert.onnx
# ONNX_TOKENIZER_PATH=model_engine/tokenizer
# DEFAULT_HAWKES_MU_0=0.01
# DEFAULT_HAWKES_ALPHA=0.5
# DEFAULT_HAWKES_BETA=1.2
# DEFAULT_HAWKES_GAMMA=0.05
